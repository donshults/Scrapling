# Scrapling Remote MCP Server Configuration
# Copy to .env and fill in values

# Required: Bearer token(s) for MCP authentication
# Comma-separated for key rotation support
SCRAPLING_API_KEY=your-bearer-token-here

# Optional: Server configuration
PORT=8000
HOST=0.0.0.0

# Optional: Session management
MAX_CONCURRENT_SESSIONS=10
SESSION_IDLE_TIMEOUT_SECONDS=1800
SESSION_CLEANUP_INTERVAL_SECONDS=60

# Optional: Logging
LOG_LEVEL=INFO

# Optional: CORS (comma-separated origins, * for all)
ALLOWED_ORIGINS=*
